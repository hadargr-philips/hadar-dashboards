# Supabase credentials — copy this file to .env.local and fill in your values.
# .env.local is gitignored and will NOT be committed to the repository.
# These values are baked into the production build (npm run build).

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here
